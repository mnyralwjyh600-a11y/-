# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./database/financial_fund.db

# Session
SESSION_SECRET=your_session_secret_key_change_this_in_production

# Organization
ORG_NAME_AR=صندوق إدارة الأموال
ORG_NAME_EN=Financial Fund Management
ORG_CURRENCY=SAR

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Security
JWT_SECRET=your_jwt_secret_key
BCRYPT_ROUNDS=10

# Features
ENABLE_BACKUP=true
BACKUP_PATH=./backups
